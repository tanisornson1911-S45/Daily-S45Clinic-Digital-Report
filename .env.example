# Copy to .env (local) and/or set in Vercel Project Settings > Environment Variables.
# Nothing here is required to run the dashboard locally — without these, the
# Facebook Ads Dashboard falls back to its bundled data snapshot.

# --- Browser-exposed (Vite requires the VITE_ prefix) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only, used by api/sync-facebook-ads.js. NEVER prefix with VITE_ or
#     these would be bundled into the client JS. ---
SUPABASE_SERVICE_ROLE_KEY=
FB_SYSTEM_USER_TOKEN=
FB_AD_ACCOUNT_IDS=225618075,221741759556998,1948728392195994,2214227468912072,1117617719803706,1711014813661620,983591777378317

# --- Existing Basic Auth gate (middleware.js) ---
DASH_USER=
DASH_PASS=
